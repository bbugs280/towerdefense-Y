# PawMind iOS POC - Environment Configuration
# Copy this file to .env and fill in your actual values

# ─────────────────────────────────────────────────────────────────────────────
# DashScope API Configuration
# Get your API key from: https://dashscope.console.aliyun.com/
# ─────────────────────────────────────────────────────────────────────────────

# DashScope API Key (required)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# TTS Configuration
# ─────────────────────────────────────────────────────────────────────────────

# TTS Provider: cosyvoice or native
# - cosyvoice: Uses DashScope CosyVoice API (better quality, Cantonese support)
# - native: Uses AVSpeechSynthesizer (offline fallback)
TTS_PROVIDER=cosyvoice

# TTS Model (only used if TTS_PROVIDER=cosyvoice)
# Options: cosyvoice-v3.5-flash, cosyvoice-v3.5-plus, cosyvoice-v2
TTS_MODEL=cosyvoice-v3.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# Default Dog Profile (from Flutter/Expo config)
# ─────────────────────────────────────────────────────────────────────────────

# Default Language: en, zh, yue, ja
DEFAULT_LANGUAGE=yue

# Default Gender: boy, girl
DEFAULT_GENDER=girl

# Default Character Prompt
DEFAULT_CHARACTER=You are a friendly, curious dog looking at a photo. Analyze what the dog in the photo is thinking or feeling. Be playful and enthusiastic in your response. Keep your response under 2 sentences.

# ─────────────────────────────────────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Frame capture interval (milliseconds)
FRAME_INTERVAL_MS=5000

# JPEG quality (0.0 - 1.0)
JPEG_QUALITY=0.6

# Frame resolution (width x height)
FRAME_WIDTH=480
FRAME_HEIGHT=360

# ─────────────────────────────────────────────────────────────────────────────
# Debug Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Enable debug mode (shows latency overlay, logs)
DEBUG_MODE=true

# Enable cost tracking display
SHOW_COST=true
